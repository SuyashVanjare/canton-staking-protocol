module Staking.Test.SlashingTest where

import Daml.Script
import DA.Assert
import DA.Date as D
import DA.Time
import DA.List (head, null)
import DA.Optional (isSome)

-- Main contract modules - assuming these exist and have the specified structure
import Staking.Pool (Pool(..), PoolStatus(..), SlashEvent(..))
import Staking.Delegation (Delegation(..))
import Staking.Token (Token(..))

-- | Test Suite for all slashing scenarios.
slashingTests : Script ()
slashingTests = script do
  log ""
  log "──────────────────────────────────"
  log "Running Staking Slashing Tests"
  log "──────────────────────────────────"
  testSuccessfulSlash
  testUnauthorizedSlashAttempt
  testSlashProportions
  testUnjailAfterSlash
  log "✓ All slashing tests passed."
  log "──────────────────────────────────"

-- | Test a valid slash operation by the designated slasher.
-- Verifies:
-- - Pool status changes to Jailed.
-- - Total stake is reduced by the penalty amount.
-- - Individual delegations are reduced proportionally.
-- - A SlashEvent contract is created.
-- - New delegations are blocked while jailed.
testSuccessfulSlash : Script ()
testSuccessfulSlash = script do
  log "--> Running test: testSuccessfulSlash"
  -- === Setup ===
  now <- getTime
  operator <- allocateParty "Operator"
  slasher <- allocateParty "Slasher"
  treasury <- allocateParty "Treasury"
  delegator1 <- allocateParty "Delegator1"

  poolCid <- setupInitialPool operator slasher treasury now
  pool <- fetch poolCid

  let operatorStakeAmount = 1_000_000.0
  let delegator1StakeAmount = 500_000.0
  _ <- setupDelegation operator poolCid operatorStakeAmount
  _ <- setupDelegation delegator1 poolCid delegator1StakeAmount

  -- Refresh pool state after delegations to get updated totalStake
  updatedPoolCid <- fst <$> queryContractId operator poolCid
  updatedPool <- fetch updatedPoolCid

  -- === Act ===
  let slashReason = "Validator downtime > 24 hours"
  slashedPoolCid <- submit slasher do
    exerciseCmd updatedPoolCid (Slash with reason = slashReason)

  -- === Assert ===
  -- 1. Verify pool state
  slashedPool <- fetch slashedPoolCid
  let expectedSlashedAmount = updatedPool.totalStake * pool.slashPenalty
  let expectedNewTotalStake = updatedPool.totalStake - expectedSlashedAmount

  slashedPool.status === Jailed
  slashedPool.totalStake === expectedNewTotalStake
  assertMsg "lastSlashedAt timestamp should be updated" (slashedPool.lastSlashedAt > pool.lastSlashedAt)

  -- 2. Verify individual delegations were reduced. Query for the new contracts.
  (newOpDelCid, _) <- queryContractId operator (Delegation with delegator = operator, poolId = pool.poolId)
  opDelegationSlashed <- fetch newOpDelCid
  (newD1DelCid, _) <- queryContractId delegator1 (Delegation with delegator = delegator1, poolId = pool.poolId)
  d1DelegationSlashed <- fetch newD1DelCid

  opDelegationSlashed.amount === operatorStakeAmount * (1.0 - pool.slashPenalty)
  d1DelegationSlashed.amount === delegator1StakeAmount * (1.0 - pool.slashPenalty)

  -- 3. Verify slash event
  (slashEventCid, _) <- queryContractId slasher (SlashEvent with poolId = pool.poolId, slasher)
  slashEvent <- fetch slashEventCid
  slashEvent.reason === slashReason
  slashEvent.amountSlashed === expectedSlashedAmount

  -- 4. Verify new delegations are blocked
  delegator2 <- allocateParty "Delegator2"
  _ <- setupDelegationToken delegator2 operator 100.0
  submitMustFail delegator2 do
    exerciseCmd slashedPoolCid (Delegate with amount = 100.0)

  log "<-- PASSED: testSuccessfulSlash"


-- | Test that an unauthorized party cannot slash a pool.
testUnauthorizedSlashAttempt : Script ()
testUnauthorizedSlashAttempt = script do
  log "--> Running test: testUnauthorizedSlashAttempt"
  -- === Setup ===
  now <- getTime
  operator <- allocateParty "Operator"
  slasher <- allocateParty "Slasher"
  treasury <- allocateParty "Treasury"
  delegator <- allocateParty "RandomDelegator"

  poolCid <- setupInitialPool operator slasher treasury now
  _ <- setupDelegation operator poolCid 1000.0
  updatedPoolCid <- fst <$> queryContractId operator poolCid

  -- === Act & Assert ===
  log "Attempting slash by operator (should fail)..."
  submitMustFail operator do
    exerciseCmd updatedPoolCid (Slash with reason = "Unauthorized slash by operator")

  log "Attempting slash by delegator (should fail)..."
  submitMustFail delegator do
    exerciseCmd updatedPoolCid (Slash with reason = "Unauthorized slash by delegator")

  log "<-- PASSED: testUnauthorizedSlashAttempt"

-- | Test slashing correctly reduces stake for multiple delegators proportionally.
testSlashProportions : Script ()
testSlashProportions = script do
  log "--> Running test: testSlashProportions"
  -- === Setup ===
  now <- getTime
  operator <- allocateParty "Operator"
  slasher <- allocateParty "Slasher"
  treasury <- allocateParty "Treasury"
  d1 <- allocateParty "Delegator1"
  d2 <- allocateParty "Delegator2"

  poolCid <- setupInitialPool operator slasher treasury now
  pool <- fetch poolCid

  let opAmount = 10_000.0
  let d1Amount = 5_000.0
  let d2Amount = 15_000.0

  _ <- setupDelegation operator poolCid opAmount
  _ <- setupDelegation d1 poolCid d1Amount
  _ <- setupDelegation d2 poolCid d2Amount

  updatedPoolCid <- fst <$> queryContractId operator poolCid
  updatedPool <- fetch updatedPoolCid

  -- === Act ===
  slashedPoolCid <- submit slasher do
    exerciseCmd updatedPoolCid (Slash with reason = "Proportionality test")

  -- === Assert ===
  slashedPool <- fetch slashedPoolCid
  slashedPool.totalStake === updatedPool.totalStake * (1.0 - pool.slashPenalty)

  (newOpDelCid, _) <- queryContractId operator (Delegation with delegator = operator, poolId = pool.poolId)
  opDelSlashed <- fetch newOpDelCid
  (newD1DelCid, _) <- queryContractId d1 (Delegation with delegator = d1, poolId = pool.poolId)
  d1DelSlashed <- fetch newD1DelCid
  (newD2DelCid, _) <- queryContractId d2 (Delegation with delegator = d2, poolId = pool.poolId)
  d2DelSlashed <- fetch newD2DelCid

  opDelSlashed.amount === opAmount * (1.0 - pool.slashPenalty)
  d1DelSlashed.amount === d1Amount * (1.0 - pool.slashPenalty)
  d2DelSlashed.amount === d2Amount * (1.0 - pool.slashPenalty)

  log "<-- PASSED: testSlashProportions"

-- | Test that an operator can unjail a pool after the cooldown period.
testUnjailAfterSlash : Script ()
testUnjailAfterSlash = script do
  log "--> Running test: testUnjailAfterSlash"
  -- === Setup ===
  let startTime = time (D.date 2024 D.Jan 1) 0 0 0
  setTime startTime
  operator <- allocateParty "Operator"
  slasher <- allocateParty "Slasher"
  treasury <- allocateParty "Treasury"

  poolCid <- setupInitialPool operator slasher treasury startTime
  _ <- setupDelegation operator poolCid 1000.0

  updatedPoolCid <- fst <$> queryContractId operator poolCid
  slashedPoolCid <- submit slasher do
    exerciseCmd updatedPoolCid (Slash with reason = "Testing unjailing")
  slashedPool <- fetch slashedPoolCid

  -- === Act & Assert ===
  -- 1. Try to unjail immediately. This should fail.
  log "Attempting to unjail before jail period ends (should fail)..."
  submitMustFail operator do
    exerciseCmd slashedPoolCid Unjail

  -- 2. Advance time past the jail period
  let timeAfterJail = addRelTime startTime slashedPool.jailPeriod
  setTime (timeAfterJail `addRelTime` seconds 1)
  log $ "Time advanced past jail period to " <> show timeAfterJail

  -- 3. Unjail successfully.
  unjailedPoolCid <- submit operator do
    exerciseCmd slashedPoolCid Unjail
  unjailedPool <- fetch unjailedPoolCid
  unjailedPool.status === Active

  -- 4. Verify delegations are now allowed.
  delegator2 <- allocateParty "Delegator2"
  _ <- setupDelegation delegator2 unjailedPoolCid 100.0
  (delegationCid, _) <- queryContractId delegator2 (Delegation with delegator = delegator2)
  delegation <- fetch delegationCid
  delegation.amount === 100.0

  log "<-- PASSED: testUnjailAfterSlash"


-- === Test Helper Functions ===

-- | Creates a standard pool for tests with default parameters.
setupInitialPool : Party -> Party -> Party -> Time -> Script (ContractId Pool)
setupInitialPool operator slasher treasury now =
  submit operator do
    createCmd Pool
      with
        poolId = "test-pool-01"
        operator
        slasher
        treasury
        tokenId = "TEST_TOKEN"
        totalStake = 0.0
        status = Active
        slashPenalty = 0.05 -- 5% penalty
        jailPeriod = hours 24
        unbondingPeriod = days 21
        createdAt = now
        lastSlashedAt = now

-- | Mints a token for a party. Assumes operator is the issuer.
setupDelegationToken : Party -> Party -> Decimal -> Script (ContractId Token)
setupDelegationToken forParty issuer amount =
  submit issuer do
    createCmd Token with owner = forParty, issuer, quantity = amount

-- | Mints a token and creates a delegation in one step for a given party and amount.
setupDelegation: Party -> ContractId Pool -> Decimal -> Script (ContractId Delegation)
setupDelegation delegator poolCid amount = do
  pool <- fetch poolCid
  _ <- setupDelegationToken delegator pool.operator amount
  submit delegator do
    exerciseCmd poolCid (Delegate with amount)