module StakingTest where

import Daml.Script
import DA.Assert
import DA.Date as D
import DA.Time as T

import Staking
import Unbonding

-- | A minimal IOU template for testing purposes.
template Iou
  with
    issuer : Party
    owner : Party
    asset : Text
    amount : Decimal
  where
    signatory issuer, owner

    nonconsuming choice Split : (ContractId Iou, ContractId Iou)
      controller owner
      with
        splitAmount: Decimal
      do
        assertMsg "Split amount must be positive" (splitAmount > 0.0)
        assertMsg "Split amount cannot exceed total amount" (splitAmount <= amount)
        let remainingAmount = amount - splitAmount
        splitCid <- create this with amount = splitAmount
        remainingCid <- create this with amount = remainingAmount
        return (splitCid, remainingCid)

-- | A minimal Slashing Rules template for testing purposes.
template SlashingRules
  with
    operator: Party
  where
    signatory operator

-- | Test suite for the main staking lifecycle.
stakingTests = script do
  test_full_staking_lifecycle
  test_multiple_delegators_share_rewards
  test_delegation_fails_below_minimum
  test_unbonding_claim_fails_before_cooldown

-- | Helper to set up the common test environment.
setup = do
  operator <- allocatePartyWithHint "Operator" (PartyIdHint "operator")
  validator <- allocatePartyWithHint "Validator" (PartyIdHint "validator")
  delegator1 <- allocatePartyWithHint "Delegator1" (PartyIdHint "delegator1")
  delegator2 <- allocatePartyWithHint "Delegator2" (PartyIdHint "delegator2")
  tokenIssuer <- allocatePartyWithHint "TokenIssuer" (PartyIdHint "token-issuer")
  rewardIssuer <- allocatePartyWithHint "RewardIssuer" (PartyIdHint "reward-issuer")

  let
    stakedAsset = "STAKE"
    rewardAsset = "REWARD"

  now <- getTime

  slashingRulesCid <- submit operator do createCmd SlashingRules with operator

  let
    poolConfig = PoolConfig with
      operator
      validator
      stakedAsset
      rewardAsset
      unbondingPeriod = D.days 30
      minDelegation = 10.0
      slashingRulesCid

  poolConfigCid <- submit operator do createCmd poolConfig

  poolCid <- submit validator do
    createCmd Pool with
      configCid = poolConfigCid
      totalStaked = 0.0
      totalShares = 0.0
      lastRewardUpdate = now
      isPaused = False

  -- Allocate initial assets for delegators and rewards
  d1Iou <- submit tokenIssuer do
    createCmd Iou with issuer = tokenIssuer, owner = delegator1, asset = stakedAsset, amount = 1000.0
  d2Iou <- submit tokenIssuer do
    createCmd Iou with issuer = tokenIssuer, owner = delegator2, asset = stakedAsset, amount = 1000.0
  rewardIou <- submit rewardIssuer do
    createCmd Iou with issuer = rewardIssuer, owner = operator, asset = rewardAsset, amount = 5000.0

  return (operator, validator, delegator1, delegator2, tokenIssuer, poolConfig, poolCid, d1Iou, d2Iou, rewardIou)

test_full_staking_lifecycle = script do
  (operator, validator, delegator1, _, tokenIssuer, poolConfig, poolCid0, d1Iou0, _, _) <- setup

  -- 1. Delegate
  let delegationAmount = 100.0
  (d1Iou1, _) <- submit delegator1 do exerciseCmd d1Iou0 Split with splitAmount = delegationAmount

  offerCid <- submit delegator1 do
    createCmd DelegationOffer with
      delegator = delegator1
      poolCid = poolCid0
      stakedAssetCid = d1Iou1

  (delegationCid, poolCid1) <- submit validator do
    exerciseCmd offerCid AcceptDelegation

  -- Assert delegation state
  [(_, delegation)] <- query delegator1
  delegation.delegator === delegator1
  delegation.shares === delegationAmount
  [(_, pool1)] <- query validator
  pool1.totalStaked === delegationAmount
  pool1.totalShares === delegationAmount

  -- 2. Accrue Rewards
  passTime (D.days 180)
  now <- getTime

  -- Use a dummy reward amount for simplicity
  let rewardAmount = 5.0
  rewardIouCid <- submit operator do
    createCmd Iou with issuer = tokenIssuer, owner = operator, asset = poolConfig.stakedAsset, amount = rewardAmount

  poolCid2 <- submit operator do
    exerciseCmd poolCid1 AccrueRewards with rewardIouCid; currentTime = now

  -- Assert reward accrual
  [(_, pool2)] <- query validator
  pool2.totalStaked === 105.0 -- 100 original + 5 reward
  pool2.totalShares === 100.0 -- Shares don't change
  let sharePrice = pool2.totalStaked / pool2.totalShares
  sharePrice === 1.05

  -- 3. Initiate Unbonding
  (unbondingRequestCid, _poolCid3) <- submit delegator1 do
    exerciseCmd delegationCid InitiateUnbonding with sharesToUnbond = delegation.shares

  -- Assert unbonding request state
  [(_, req)] <- query delegator1
  req.delegator === delegator1
  -- Unbonding amount is shares * current share price
  req.unbondingAmount === (delegation.shares * sharePrice)
  req.unbondingAmount === 105.0
  req.asset === poolConfig.stakedAsset
  req.claimableAt === T.addRelTime now poolConfig.unbondingPeriod

  -- 4. Claim Unbonded Tokens
  passTime poolConfig.unbondingPeriod
  passTime (seconds 1) -- Pass a little extra to avoid boundary condition errors

  _claimedIouCid <- submit delegator1 do
    exerciseCmd unbondingRequestCid ClaimUnbonded with tokenIssuer

  -- Assert final state
  unbondingContracts <- query delegator1
  unbondingContracts === [] -- Request contract is archived

  finalIous <- query delegator1
  let finalBalance = sum (map (\(_, c) -> c.amount) finalIous)
  -- Initial 1000 - 100 staked + 105 claimed
  finalBalance === 1005.0

test_multiple_delegators_share_rewards = script do
  (operator, validator, delegator1, delegator2, tokenIssuer, poolConfig, poolCid0, d1Iou0, d2Iou0, _) <- setup

  -- Delegator 1 stakes 100
  let d1Amount = 100.0
  (d1Iou1, _) <- submit delegator1 do exerciseCmd d1Iou0 Split with splitAmount = d1Amount
  offer1Cid <- submit delegator1 do createCmd DelegationOffer with delegator = delegator1; poolCid = poolCid0; stakedAssetCid = d1Iou1
  (d1DelegationCid, poolCid1) <- submit validator do exerciseCmd offer1Cid AcceptDelegation

  -- Delegator 2 stakes 300
  let d2Amount = 300.0
  (d2Iou1, _) <- submit delegator2 do exerciseCmd d2Iou0 Split with splitAmount = d2Amount
  offer2Cid <- submit delegator2 do createCmd DelegationOffer with delegator = delegator2; poolCid = poolCid1; stakedAssetCid = d2Iou1
  (d2DelegationCid, poolCid2) <- submit validator do exerciseCmd offer2Cid AcceptDelegation

  -- Pool state: 400 total staked, 400 total shares. Share price = 1.0
  [(_, pool2)] <- query validator
  pool2.totalStaked === 400.0
  pool2.totalShares === 400.0

  -- Accrue 40 in rewards
  passTime (D.days 90)
  now <- getTime
  let rewardAmount = 40.0
  rewardIouCid <- submit operator do createCmd Iou with issuer = tokenIssuer, owner = operator, asset = poolConfig.stakedAsset, amount = rewardAmount
  poolCid3 <- submit operator do exerciseCmd poolCid2 AccrueRewards with rewardIouCid; currentTime = now

  -- Pool state: 440 total staked, 400 total shares. Share price = 1.1
  [(_, pool3)] <- query validator
  pool3.totalStaked === 440.0
  pool3.totalShares === 400.0
  let sharePrice = pool3.totalStaked / pool3.totalShares
  sharePrice === 1.1

  -- Delegator 1 unbonds all 100 shares
  (d1UnbondCid, _poolCid4) <- submit delegator1 do exerciseCmd d1DelegationCid InitiateUnbonding with sharesToUnbond = 100.0
  [(_, d1Req)] <- query delegator1
  -- Expected amount: 100 shares * 1.1 share price = 110.0
  d1Req.unbondingAmount === 110.0

  -- Delegator 2 unbonds all 300 shares
  (d2UnbondCid, _poolCid5) <- submit delegator2 do exerciseCmd d2DelegationCid InitiateUnbonding with sharesToUnbond = 300.0
  [(_, d2Req)] <- query delegator2
  -- Expected amount: 300 shares * 1.1 share price = 330.0
  d2Req.unbondingAmount === 330.0

test_delegation_fails_below_minimum = script do
  (_, validator, delegator1, _, _, poolConfig, poolCid, d1Iou, _, _) <- setup

  let smallAmount = poolConfig.minDelegation - 1.0
  (smallIou, _) <- submit delegator1 do exerciseCmd d1Iou Split with splitAmount = smallAmount

  -- Attempt to create an offer with an amount below the minimum
  submitMustFail delegator1 do
    createCmd DelegationOffer with
      delegator = delegator1
      poolCid
      stakedAssetCid = smallIou

test_unbonding_claim_fails_before_cooldown = script do
  (_, validator, delegator1, _, tokenIssuer, poolConfig, poolCid0, d1Iou0, _, _) <- setup

  -- Delegate
  let delegationAmount = 100.0
  (d1Iou1, _) <- submit delegator1 do exerciseCmd d1Iou0 Split with splitAmount = delegationAmount
  offerCid <- submit delegator1 do createCmd DelegationOffer with delegator = delegator1; poolCid = poolCid0; stakedAssetCid = d1Iou1
  (delegationCid, _poolCid1) <- submit validator do exerciseCmd offerCid AcceptDelegation
  [(_, delegation)] <- query delegator1

  -- Initiate Unbonding
  (unbondingRequestCid, _) <- submit delegator1 do
    exerciseCmd delegationCid InitiateUnbonding with sharesToUnbond = delegation.shares

  -- Attempt to claim immediately
  submitMustFail delegator1 do
    exerciseCmd unbondingRequestCid ClaimUnbonded with tokenIssuer

  -- Pass some time, but not enough
  passTime (D.days 15)
  submitMustFail delegator1 do
    exerciseCmd unbondingRequestCid ClaimUnbonded with tokenIssuer

  -- Pass the full period, now it should succeed
  passTime (D.days 16) -- 15 + 16 > 30
  _ <- submit delegator1 do
    exerciseCmd unbondingRequestCid ClaimUnbonded with tokenIssuer
  pure ()